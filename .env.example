# ============================================================================
# SECURITY: API KEYS AND SECRETS
# 
#  NEVER commit this file with real values to version control!
#  Add .env to your .gitignore file
#  These values are ONLY read by the Node.js server (vite.config.ts proxy)
#  They are NEVER bundled into the client-side JavaScript
# ============================================================================

# ---------------------------------------------------------------------------
# Amadeus Self-Service (free test tier)
# ---------------------------------------------------------------------------
# Enables LIVE flight search in dev & `vite preview` mode.
# 
# Security Notes:
# - Keys are stored server-side only, never exposed to browser
# - Token is cached with expiration (30 second buffer)
# - API requests timeout after 30 seconds (DoS protection)
# - Input validation prevents SQL injection and path traversal
#
# Setup:
# 1. Create free account: https://developers.amadeus.com/register
# 2. Create "Self-Service" app in test environment
# 3. Copy API Key & API Secret from dashboard
# 4. Add values below (without quotes)
#
# Rate Limits:
# - 100 requests per minute per IP (configured in vite.config.ts)
# - Global limit: 1000 requests per minute
#
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# RapidAPI - Skyscanner Flights API
# ---------------------------------------------------------------------------
# Alternative flight data source with generous free tier
#
# Security Notes:
# - Key is validated for minimum length (20 chars)
# - Request timeout: 30 seconds
# - Rate limited: 10 requests/minute per IP
#
# Setup:
# 1. Sign up: https://rapidapi.com/principalapis/api/skyscanner80
# 2. Subscribe to "BASIC" plan ($0.00/month)
# 3. Copy X-RapidAPI-Key from dashboard
#
# RAPIDAPI_KEY=

# ---------------------------------------------------------------------------
# API Configuration
# ---------------------------------------------------------------------------
# Request timeout in milliseconds (default: 30000)
# Prevents long-running requests from consuming server resources
# API_TIMEOUT_MS=30000

# ---------------------------------------------------------------------------
# Client-Side Configuration (Safe for browser)
# ---------------------------------------------------------------------------
# These values are safe to expose to the client (no secrets)
# VITE_ prefix makes them available in browser via import.meta.env

# Public app URL (used for redirects, social sharing)
# VITE_APP_URL=http://localhost:5173

# Enable analytics (only if you have privacy-compliant setup)
# VITE_ENABLE_ANALYTICS=false

# Enable debug mode (never true in production!)
# VITE_ENABLE_DEBUG=false

# ============================================================================
# PRODUCTION DEPLOYMENT SECURITY CHECKLIST
# ============================================================================
# 
# [ ] All secrets stored in environment variables (not in code)
# [ ] .env file added to .gitignore
# [ ] Rate limiting enabled (configured in vite.config.ts)
# [ ] CSP headers configured for production domain
# [ ] HSTS header enabled (uncomment in vite.config.ts)
# [ ] Source maps disabled in production (vite.config.ts)
# [ ] HTTPS enforced
# [ ] Security headers verified with securityheaders.com
#
# ============================================================================
