# ============================================================================
# BACKEND ENVIRONMENT VARIABLES - Cloudflare Worker
# ⚠️  NEVER COMMIT THIS FILE WITH REAL VALUES!
# Add to .gitignore: .env.backend
# ============================================================================

# ============================================================================
# GOOGLE OAUTH - Required for authentication
# Get from: https://console.cloud.google.com/apis/credentials
# ============================================================================
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ============================================================================
# JWT SECRET - For signing authentication tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================================
JWT_SECRET=generate_a_64_character_random_string_here

# ============================================================================
# STRIPE - Required for payments
# Get from: https://dashboard.stripe.com/apikeys
# ============================================================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_PRICE_ID=price_your_price_id_here

# Webhook secret - Get from Stripe Dashboard > Developers > Webhooks
# Endpoint URL: https://your-worker.your-subdomain.workers.dev/api/payments/webhook
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ============================================================================
# APP CONFIGURATION
# ============================================================================
APP_URL=https://vantagetravel.pages.dev

# ============================================================================
# CLOUDFLARE D1 DATABASE - Create in Dashboard
# Workers & Pages > D1 > Create Database
# ============================================================================
# Database ID (found in D1 dashboard after creating)
DB_DATABASE_ID=your_d1_database_id_here

# ============================================================================
# SECURITY NOTES:
# ============================================================================
# 
# 1. ALL of these secrets are SERVER-SIDE ONLY
# 2. They are stored in Cloudflare Worker environment variables (encrypted)
# 3. NEVER expose these to the frontend/browser
# 4. NEVER commit real values to git
# 5. Use different values for production vs testing
#
# To set these in Cloudflare:
# 1. Go to https://dash.cloudflare.com/ > Workers & Pages > Your Worker
# 2. Settings > Variables > Add variables
# 3. Set all the above keys with your real values
#
# ============================================================================
# SETUP CHECKLIST:
# ============================================================================
#
# [ ] Create Google OAuth credentials (Web application type)
# [ ] Create Stripe account and get API keys
# [ ] Create subscription product in Stripe Dashboard
# [ ] Create D1 database in Cloudflare Dashboard
# [ ] Run database schema (db-schema.sql) in D1 console
# [ ] Set up Stripe webhook endpoint
# [ ] Generate JWT secret (64+ random characters)
# [ ] Add all secrets to Cloudflare Worker environment
# [ ] Test OAuth flow locally
# [ ] Deploy and test in production
#
# ============================================================================
